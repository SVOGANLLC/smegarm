# Copy to `.env` on the VPS (next to docker-compose.yml).

# ============================================================
# PUBLIC (baked into browser bundle at build time)
# ============================================================
VITE_SUPABASE_URL=https://smeg.am
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=smegarm

# First-party analytics (product views + site search log).
# Local dev: false. Production (smeg.am): true after analytics migrations applied.
VITE_ANALYTICS_ENABLED=false

# Fuzzy search (typos, synonyms). Off by default — enable after fuzzy_search migration.
VITE_FUZZY_SEARCH_ENABLED=false

# ============================================================
# SERVER (runtime, keep secret)
# ============================================================
SUPABASE_URL=http://smeg-api:8000
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=smegarm
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used for ConverseBank returnUrl and Telegram webhook.
# After DNS+SSL: https://smeg.am
PUBLIC_BASE_URL=https://smeg.am

# ConverseBank online payments
CONVERSE_MERCHANT_ID=
CONVERSE_TOKEN=

# Telegram bot (@smegarmbot) — order notifications
TELEGRAM_BOT_TOKEN=

# Optional: force Telegram Bot API to a reachable DC IP (Reg.ru VPS may block others).
# TELEGRAM_API_FORCE_IP=149.154.167.220

PORT=3000
