# Copy to .env and fill in. Generate keys: node deploy/scripts/generate-keys.mjs

POSTGRES_PASSWORD=change-me-long-random

JWT_SECRET=change-me-64-hex-chars
ANON_KEY=eyJ...
SERVICE_ROLE_KEY=eyJ...

# Public URLs (update after DNS + SSL)
SITE_URL=https://smeg.am
API_EXTERNAL_URL=https://smeg.am/auth/v1
ADDITIONAL_REDIRECT_URLS=https://smeg.am/**,https://smeg.am/admin

# SMTP optional — GoTrue uses autoconfirm=true without SMTP for now
SMTP_ADMIN_EMAIL=noreply@smeg.am
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
